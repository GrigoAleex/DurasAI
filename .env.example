WHISPER_BIN=whisper-cli
WHISPER_MODEL=./models/whisper/ggml-base.bin
WHISPER_LANGUAGE=en

LLM_API_URL=http://127.0.0.1:8080/v1/chat/completions
LLM_MODEL=mistral
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=128

INTERNET_MODE=auto
INTERNET_PROVIDER=tavily
INTERNET_TIMEOUT_SEC=6
INTERNET_TOP_K=3
TAVILY_API_KEY=YOUR_TAVILY_API_KEY
TAVILY_SEARCH_DEPTH=basic|advanced

PIPER_MODEL=./models/piper/en_GB-jenny_dioco-medium.onnx
PIPER_CONFIG=./models/piper/en_GB-jenny_dioco-medium.onnx.json

INPUT_WAV=./audio/input.wav
OUTPUT_WAV=./audio/output.wav

SYSTEM_PROMPT=You are a concise, helpful voice assistant.
RECORD_SECONDS=5
